CC      := clang
#CFLAGS  := -Wall -Wextra -pedantic -std=c17 -O2 -g -fPIC -fvisibility=hidden
CFLAGS  := -arch $(shell uname -m) -Wall -Wextra -pedantic -std=c17 -O2 -g -fPIC -fvisibility=hidden

DEPFLAGS = -MT $@ -MMD -MP -MF obj/$*.d

SRCS    := $(wildcard common/src/*.c) $(wildcard core/src/*.c)
OBJS    := $(patsubst %.c,obj/%.o,$(notdir $(SRCS)))
DEPS    := $(OBJS:.o=.d)
# Define relative lookup roots to grab parent directory location definitions
ROOT_DIR       := $(shell cd .. && pwd)
SDL_BUILD_DIR  := $(ROOT_DIR)/build/sdl_build

TARGET  := libengine.dylib
INC_FLAGS := -Icommon/include -Icore/include -I../include $(GLOBAL_INC)

.PHONY: all clean

all: $(TARGET)

$(TARGET): $(OBJS)
	$(CC) -shared -Wl,-install_name,@rpath/$(TARGET) \
		-L$(SDL_BUILD_DIR)/lib -lSDL3 \
		-o $@ $^
	@mkdir -p ../build/obj
	@cp obj/*.json.tmp ../build/obj/ 2>/dev/null || true

# --- THE FIX: Written explicitly inside the recipe rule using a single dollar sign ---
obj/%.o: common/src/%.c
	@mkdir -p obj
	$(CC) $(DEPFLAGS) -MJ obj/$*.json.tmp $(CFLAGS) $(INC_FLAGS) -c $< -o $@

obj/%.o: core/src/%.c
	@mkdir -p obj
	$(CC) $(DEPFLAGS) -MJ obj/$*.json.tmp $(CFLAGS) $(INC_FLAGS) -c $< -o $@

clean:
	rm -rf obj $(TARGET)

-include $(DEPS)
